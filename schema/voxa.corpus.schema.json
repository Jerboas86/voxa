{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/voxa/voxa.corpus.schema.json",
  "title": "Voxa Corpus Manifest",
  "description": "Schema for the Voxa corpus-level manifest file voxa.corpus.json. Cross-file validation must additionally ensure that every referenced sample metadata record uses the same exact language.bcp47 value as the corpus manifest. Corpus-level proxy signals are optional; multilingual dataset calibration proxies are described by voxa.dataset.json.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "corpus_id",
    "name",
    "version",
    "created_at",
    "status",
    "licenses",
    "language",
    "release_root",
    "integrity",
    "samples"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "corpus_id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "released",
        "deprecated",
        "archived"
      ]
    },
    "release_root": {
      "type": "string",
      "minLength": 1
    },
    "licenses": {
      "$ref": "#/$defs/licenses"
    },
    "citation": {
      "$ref": "#/$defs/citation"
    },
    "language": {
      "$ref": "#/$defs/language"
    },
    "metric_pipeline": {
      "$ref": "#/$defs/metricPipeline"
    },
    "corpus_statistics": {
      "$ref": "#/$defs/corpusStatistics"
    },
    "proxy_signals": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/proxySignal"
      }
    },
    "integrity": {
      "$ref": "#/$defs/corpusIntegrity"
    },
    "samples": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/sampleReference"
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "released"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "properties": {
          "integrity": {
            "required": [
              "manifest_hash_algorithm",
              "manifest_hash",
              "signature_algorithm",
              "public_key_id"
            ]
          }
        }
      }
    },
    {
      "properties": {
        "proxy_signals": {
          "contains": {
            "type": "object",
            "properties": {
              "kind": {
                "const": "white_noise"
              },
              "target_metric": {
                "const": "overall_rms_dbfs"
              }
            },
            "required": [
              "kind",
              "target_metric"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "proxy_signals": {
            "contains": {
              "type": "object",
              "properties": {
                "kind": {
                  "const": "white_noise"
                },
                "target_metric": {
                  "const": "overall_rms_dbfs"
                }
              },
              "required": [
                "kind",
                "target_metric"
              ]
            }
          }
        },
        "required": [
          "proxy_signals"
        ]
      },
      "then": {
        "required": [
          "corpus_statistics"
        ],
        "properties": {
          "corpus_statistics": {
            "required": [
              "overall_rms_dbfs"
            ]
          }
        }
      }
    }
  ],
  "$defs": {
    "audioContainer": {
      "type": "string",
      "enum": [
        "wav",
        "flac",
        "mp3",
        "ogg",
        "opus"
      ]
    },
    "language": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "bcp47"
      ],
      "properties": {
        "bcp47": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "license": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "name",
        "url",
        "usage"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "usage": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "licenses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/license"
      }
    },
    "citation": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "title",
        "authors",
        "url"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "authors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "metricPipeline": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "version",
        "parameters"
      ],
      "properties": {
        "version": {
          "type": "string",
          "minLength": 1
        },
        "parameters": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "summaryStatistic": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "mean",
        "std",
        "min",
        "max",
        "p10",
        "p50",
        "p90"
      ],
      "properties": {
        "mean": {
          "type": "number"
        },
        "std": {
          "type": "number"
        },
        "min": {
          "type": "number"
        },
        "max": {
          "type": "number"
        },
        "p10": {
          "type": "number"
        },
        "p50": {
          "type": "number"
        },
        "p90": {
          "type": "number"
        }
      }
    },
    "ltasInline": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "method",
        "analysis_sample_rate_hz",
        "frame_ms",
        "hop_ms",
        "window",
        "n_fft",
        "level_definition",
        "frequency_hz",
        "level_db"
      ],
      "properties": {
        "method": {
          "type": "string",
          "minLength": 1
        },
        "analysis_sample_rate_hz": {
          "type": "integer",
          "minimum": 1
        },
        "frame_ms": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "hop_ms": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "window": {
          "type": "string",
          "minLength": 1
        },
        "n_fft": {
          "type": "integer",
          "minimum": 1
        },
        "level_definition": {
          "type": "string",
          "minLength": 1
        },
        "resample_method": {
          "type": "string",
          "minLength": 1
        },
        "frequency_hz": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "number"
          }
        },
        "level_db": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "number"
          }
        }
      }
    },
    "ltasReference": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "method",
        "analysis_sample_rate_hz",
        "frame_ms",
        "hop_ms",
        "window",
        "n_fft",
        "level_definition",
        "path",
        "format"
      ],
      "properties": {
        "method": {
          "type": "string",
          "minLength": 1
        },
        "analysis_sample_rate_hz": {
          "type": "integer",
          "minimum": 1
        },
        "frame_ms": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "hop_ms": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "window": {
          "type": "string",
          "minLength": 1
        },
        "n_fft": {
          "type": "integer",
          "minimum": 1
        },
        "level_definition": {
          "type": "string",
          "minLength": 1
        },
        "resample_method": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!/).+"
        },
        "format": {
          "type": "string",
          "enum": [
            "json",
            "csv"
          ]
        },
        "hash_algorithm": {
          "type": "string",
          "enum": [
            "sha256",
            "sha512"
          ]
        },
        "hash": {
          "type": "string",
          "minLength": 1
        },
        "bin_count": {
          "type": "integer",
          "minimum": 1
        }
      },
      "allOf": [
        {
          "if": {
            "required": [
              "hash_algorithm"
            ]
          },
          "then": {
            "required": [
              "hash"
            ]
          }
        },
        {
          "if": {
            "required": [
              "hash"
            ]
          },
          "then": {
            "required": [
              "hash_algorithm"
            ]
          }
        }
      ]
    },
    "ltas": {
      "oneOf": [
        {
          "$ref": "#/$defs/ltasInline"
        },
        {
          "$ref": "#/$defs/ltasReference"
        }
      ]
    },
    "corpusStatistics": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "sample_count": {
          "type": "integer",
          "minimum": 0
        },
        "total_duration_s": {
          "type": "number",
          "minimum": 0
        },
        "duration": {
          "$ref": "#/$defs/summaryStatistic"
        },
        "rms_dbfs": {
          "$ref": "#/$defs/summaryStatistic"
        },
        "overall_rms_dbfs": {
          "type": "number"
        },
        "integrated_lufs": {
          "$ref": "#/$defs/summaryStatistic"
        },
        "active_speech_rms_dbfs": {
          "$ref": "#/$defs/summaryStatistic"
        },
        "crest_factor_db": {
          "$ref": "#/$defs/summaryStatistic"
        },
        "peak_dbfs": {
          "$ref": "#/$defs/summaryStatistic"
        },
        "speech_activity_ratio": {
          "$ref": "#/$defs/summaryStatistic"
        },
        "loudness_range_lu": {
          "$ref": "#/$defs/summaryStatistic"
        },
        "ltas": {
          "$ref": "#/$defs/ltas"
        }
      }
    },
    "proxySignal": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "proxy_id",
        "kind",
        "target_metric",
        "rms_dbfs",
        "duration_s",
        "audio_path",
        "audio_hash"
      ],
      "properties": {
        "proxy_id": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "target_metric": {
          "type": "string",
          "minLength": 1
        },
        "rms_dbfs": {
          "type": "number"
        },
        "duration_s": {
          "type": "number",
          "minimum": 0
        },
        "audio_path": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!/).+"
        },
        "audio_hash": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "corpusIntegrity": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "manifest_hash_algorithm",
        "manifest_hash"
      ],
      "properties": {
        "manifest_hash_algorithm": {
          "type": "string",
          "enum": [
            "sha256",
            "sha512"
          ]
        },
        "manifest_hash": {
          "type": "string",
          "minLength": 1
        },
        "signature_algorithm": {
          "type": "string"
        },
        "public_key_id": {
          "type": "string"
        }
      }
    },
    "sampleReference": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "sample_id",
        "sample_revision",
        "metadata_path",
        "metadata_hash",
        "audio_path",
        "audio_hash"
      ],
      "properties": {
        "sample_id": {
          "type": "string",
          "minLength": 1
        },
        "sample_revision": {
          "type": "string",
          "minLength": 1
        },
        "metadata_path": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!/).+"
        },
        "metadata_hash": {
          "type": "string",
          "minLength": 1
        },
        "audio_path": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!/).+"
        },
        "audio_hash": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
