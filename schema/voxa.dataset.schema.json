{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/voxa/voxa.dataset.schema.json",
  "title": "Voxa Dataset Manifest",
  "description": "Schema for the Voxa dataset-level manifest file voxa.dataset.json. Cross-file validation must additionally ensure that each corpus reference matches the referenced corpus manifest and that reference_offset_db equals overall_rms_dbfs minus calibration_profile.target_rms_dbfs.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "dataset_id",
    "name",
    "version",
    "created_at",
    "status",
    "release_root",
    "corpora",
    "calibration_profile",
    "proxy_signals",
    "integrity"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "dataset_id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "released",
        "deprecated",
        "archived"
      ]
    },
    "release_root": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/).+"
    },
    "corpora": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/corpusReference"
      }
    },
    "calibration_profile": {
      "$ref": "#/$defs/calibrationProfile"
    },
    "proxy_signals": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/proxySignal"
      }
    },
    "integrity": {
      "$ref": "#/$defs/datasetIntegrity"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "released"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "properties": {
          "integrity": {
            "required": [
              "manifest_hash_algorithm",
              "manifest_hash",
              "signature_algorithm",
              "public_key_id"
            ]
          }
        }
      }
    },
    {
      "properties": {
        "proxy_signals": {
          "contains": {
            "type": "object",
            "properties": {
              "kind": {
                "const": "white_noise"
              },
              "target_metric": {
                "const": "overall_rms_dbfs"
              }
            },
            "required": [
              "kind",
              "target_metric"
            ]
          }
        }
      }
    }
  ],
  "$defs": {
    "language": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "bcp47"
      ],
      "properties": {
        "bcp47": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "corpusReference": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "corpus_id",
        "corpus_version",
        "language",
        "manifest_path",
        "manifest_hash"
      ],
      "properties": {
        "corpus_id": {
          "type": "string",
          "minLength": 1
        },
        "corpus_version": {
          "type": "string",
          "minLength": 1
        },
        "language": {
          "$ref": "#/$defs/language"
        },
        "manifest_path": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!/).+"
        },
        "manifest_hash": {
          "type": "string",
          "minLength": 1
        },
        "overall_rms_dbfs": {
          "type": "number"
        },
        "reference_offset_db": {
          "type": "number"
        }
      }
    },
    "calibrationProfile": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "profile_id",
        "method",
        "target_metric",
        "target_rms_dbfs",
        "reference_scope",
        "analysis_tolerance_db"
      ],
      "properties": {
        "profile_id": {
          "type": "string",
          "minLength": 1
        },
        "method": {
          "type": "string",
          "enum": [
            "single_dataset_reference"
          ]
        },
        "target_metric": {
          "type": "string",
          "enum": [
            "overall_rms_dbfs"
          ]
        },
        "target_rms_dbfs": {
          "type": "number"
        },
        "reference_scope": {
          "type": "string",
          "enum": [
            "dataset"
          ]
        },
        "analysis_tolerance_db": {
          "type": "number",
          "minimum": 0
        },
        "parameters": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "proxySignal": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "proxy_id",
        "kind",
        "target_metric",
        "rms_dbfs",
        "duration_s",
        "audio_path",
        "audio_hash"
      ],
      "properties": {
        "proxy_id": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "target_metric": {
          "type": "string",
          "minLength": 1
        },
        "rms_dbfs": {
          "type": "number"
        },
        "duration_s": {
          "type": "number",
          "minimum": 0
        },
        "audio_path": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!/).+"
        },
        "audio_hash": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "datasetIntegrity": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "manifest_hash_algorithm",
        "manifest_hash"
      ],
      "properties": {
        "manifest_hash_algorithm": {
          "type": "string",
          "enum": [
            "sha256",
            "sha512"
          ]
        },
        "manifest_hash": {
          "type": "string",
          "minLength": 1
        },
        "signature_algorithm": {
          "type": "string"
        },
        "public_key_id": {
          "type": "string"
        }
      }
    }
  }
}
